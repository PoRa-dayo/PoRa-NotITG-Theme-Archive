<ActorFrame OnCommand="%function(self)
        self:zoom(0.7)
end"> <children>


	<AutoActor
	Type="Quad"
	OnCommand="x,SCREEN_CENTER_X;y,SCREEN_BOTTOM-43;zoomtowidth,SCREEN_WIDTH*2;zoomtoheight,SCREEN_HEIGHT*2;diffuse,0,0,0,1;diffusealpha,0;linear,1;diffusealpha,0.7"
	OffCommand="linear,0.3;diffusealpha,0"
	/>


	<AutoActor
        File="ScreenSLGJUVMCredits underlay/moddedtheme"
        OnCommand="draworder,1010;horizalign,right;zoom,0.5;x,SCREEN_RIGHT*1.4-30;y,SCREEN_TOP+50;shadowlength,1;diffusealpha,0;linear,1;diffusealpha,1"
        OffCommand="linear,0.3;diffusealpha,0"
	/>
	<AutoActor
                Type="BitmapText"
                Text="thing"
                Font="_wendy white"
				InitCommand="horizalign,right;y,SCREEN_TOP+70;x,SCREEN_RIGHT*1.4-60;zoom,0.2"
                OnCommand="%function(self)
                self:settext('Version '..SLGJUVMInfo['Version']..' - '..SLGJUVMInfo['VersionName'])
                self:diffusealpha(0)
                self:linear(1)
                self:diffusealpha(1)
                end"
				OffCommand="accelerate,0.4;diffusealpha,0"
	/>




