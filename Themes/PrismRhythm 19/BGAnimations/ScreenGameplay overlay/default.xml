<ActorFrame> <children>

	<!-- BATTLE MODE DISPLAY NAMES -->
	<LayerType="BitmapText"
		Condition="GAMESTATE:GetPlayMode() == PLAY_MODE_RAVE"
		Font="Common normal"
		Text="@GAMESTATE:GetPlayerDisplayName(PLAYER_1)"
		OnCommand="x,SCREEN_CENTER_X-224;y,SCREEN_BOTTOM-62;shadowlength,0;diffuse,#99BBFF;zoom,.5;maxwidth,180;addy,100;sleep,0.5;decelerate,0.8;addy,-100"
		OffCommand="accelerate,0.8;addy,100"
	/>
	<Layer Type="BitmapText"
		Condition="GAMESTATE:GetPlayMode() == PLAY_MODE_RAVE"
		Font="Common normal"
		Text="@GAMESTATE:GetPlayerDisplayName(PLAYER_2)"
		OnCommand="x,SCREEN_CENTER_X+224;y,SCREEN_BOTTOM-62;shadowlength,0;diffuse,#66FFFF;zoom,.5;maxwidth,180;addy,100;sleep,0.5;decelerate,0.8;addy,-100"
		OffCommand="accelerate,0.8;addy,100"
	/>


	<!-- TITLE & TIME DISPLAY -->
	<Layer Type="ActorFrame"
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_TOP+24;addy,-100;sleep,0.5;queuecommand,TweenOn"
		OffCommand="queuecommand,TweenOff"
		ShowGameplayTopFrameMessageCommand="playcommand,TweenOn"
		HideGameplayTopFrameMessageCommand="playcommand,TweenOff"
		TweenOnCommand="decelerate,0.8;addy,+100"
		TweenOffCommand="accelerate,0.8;addy,-100"
		> <children>
		
		<Layer
			File="meter background"
		/>

		<Layer
			Type="SongMeterDisplay"
			StreamWidth="390"
			StreamPath="meter stream"
		>
			<Tip
				File="tip"
				OnCommand="diffusealpha,1"
			/>
		</Layer>

		<Layer
			File="meter frame"
		/>

		<!-- SONG TITLE TEXT -->
		<!-- This works for Dance and Battle (Rave) Modes, since neither are course modes. -->
		<Layer
			Condition="not GAMESTATE:IsCourseMode()"
			Type="BitmapText"
			Font="_eurostile normal"
			OnCommand="y,1;zoom,.6;shadowlength,0;maxwidth,600"
			InitCommand="animate,0;playcommand,Update"
			CurrentSongChangedMessageCommand="playcommand,Update"
			UpdateCommand="%SetFromSongTitleOnly"
		/>

		<!-- MARATHON MODE HUD TEXT -->
		<Layer
			Condition="GAMESTATE:GetPlayMode()==PLAY_MODE_NONSTOP"
			Type="BitmapText"
			Font="_eurostile normal"
			OnCommand="Y,-4;Zoom,.3;ShadowLength,0;MaxWidth,1200;DiffuseShift;EffectColor1,#FFFF55;EffectColor2,#FFFF55"
			InitCommand="Animate,0;PlayCommand,Update"
			CurrentCourseChangedMessageCommand="PlayCommand,Update"
			UpdateCommand="%SetCourseLabelAndName"
		/>
		<Layer
			Condition="GAMESTATE:GetPlayMode()==PLAY_MODE_NONSTOP"
			Type="BitmapText"
			Font="_eurostile normal"
			OnCommand="Y,4;Zoom,.5;ShadowLength,0;MaxWidth,760"
			InitCommand="Animate,0;PlayCommand,Update"
			CurrentSongChangedMessageCommand="PlayCommand,Update"
			UpdateCommand="%SetFromSongTitleOnly"
		/>

		<!-- SURVIVAL MODE HUD TEXT -->
		<Layer
			Condition="GAMESTATE:GetPlayMode()==PLAY_MODE_ONI"
			Type="BitmapText"
			Font="_eurostile normal"
			OnCommand="Y,-4;Zoom,.3;ShadowLength,0;MaxWidth,1200;DiffuseShift;EffectColor1,#9999FF;EffectColor2,#9999FF"
			InitCommand="Animate,0;PlayCommand,Update"
			CurrentCourseChangedMessageCommand="PlayCommand,Update"
			UpdateCommand="%SetCourseLabelAndName"
		/>
		<Layer
			Condition="GAMESTATE:GetPlayMode()==PLAY_MODE_ONI"
			Type="BitmapText"
			Font="_eurostile normal"
			OnCommand="Y,4;Zoom,.5;ShadowLength,0;MaxWidth,760"
			InitCommand="Animate,0;PlayCommand,Update"
			CurrentSongChangedMessageCommand="PlayCommand,Update"
			UpdateCommand="%SetFromSongTitleOnly"
		/>

	</children> </Layer>


	<!-- DIFFICULTY ICONS -->
	<Layer Type="ActorFrame"
		OnCommand="sleep,0.5;queuecommand,TweenOn"
		OffCommand="queuecommand,TweenOff"
		ShowGameplayTopFrameMessageCommand="playcommand,TweenOn"
		HideGameplayTopFrameMessageCommand="playcommand,TweenOff"
		> <children>
				<!-- FOR PLAYER 1-->
		
		<ActorFrame
				Condition="GAMESTATE:IsPlayerEnabled(PLAYER_1)"
				OnCommand="x,SCREEN_CENTER_X-257;y,SCREEN_TOP+25;addx,-200"
				TweenOnCommand="decelerate,0.8;addx,+200"
				TweenOffCommand="accelerate,0.8;addx,-200"><children>
			<Actor
				File="@THEME:GetPath(EC_GRAPHICS,'','_difficulty icons')"
				OnCommand="animate,0;playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				CurrentStepsP2ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self,parent) SetDifficultyFrameFromSteps(self, PLAYER_1) end"
			/>
			<Actor
				Class="DifficultyMeter"
				Type="ScreenGameplay DifficultyMeterP1"
				OnCommand="playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				CurrentStepsP2ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self) self:SetFromSteps(GAMESTATE:GetCurrentSteps(PLAYER_1)) end"
			/>
		</children></ActorFrame>
				<!-- FOR PLAYER 2-->
		
		<ActorFrame
				Condition="GAMESTATE:IsPlayerEnabled(PLAYER_2)"
				OnCommand="x,SCREEN_CENTER_X+257;y,SCREEN_TOP+25;addx,+200"
				TweenOnCommand="decelerate,0.8;addx,-200"
				TweenOffCommand="accelerate,0.8;addx,+200"><children>
			<Actor
				File="@THEME:GetPath(EC_GRAPHICS,'','_difficulty icons')"
				OnCommand="animate,0;playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				CurrentStepsP2ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self,parent) SetDifficultyFrameFromSteps(self, PLAYER_2) end"
			/>
			<Actor
				Class="DifficultyMeter"
				Type="ScreenGameplay DifficultyMeterP2"
				OnCommand="playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				CurrentStepsP2ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self) self:SetFromSteps(GAMESTATE:GetCurrentSteps(PLAYER_2)) end"
			/>
		</children></ActorFrame>
		
	</children> </Layer>



	<!-- [SCREENSTAGE] DISPLAY -->

	<Layer
		Type="Quad"
		OnCommand="diffuse,#000000;stretchto,SCREEN_LEFT,SCREEN_TOP,SCREEN_RIGHT,SCREEN_BOTTOM;diffusealpha,1;linear,0.3;diffusealpha,0"
	/>

	<Layer
		Condition="not GAMESTATE:IsDemonstration()"
		File="../_song credit display"
		OnCommand="sleep,2.5;linear,0.3;diffusealpha,0"
	/>


	<!-- DEMONSTRATION GRADIENT & DESIGNATION -->
	<Layer Class="ActorFrame"
	Condition="GAMESTATE:IsDemonstration()"><children>
		<Layer
			File="demonstration gradient"
			OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;zoomtowidth,SCREEN_WIDTH;zoomtoheight,SCREEN_HEIGHT;diffusealpha,0.8"
		/>
		<Layer
			File="demonstration logo"
			OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y-140;pulse;EffectMagnitude,1.0,0.9,0;effectclock,bgm;effectperiod,1"
		/>
	</children></Layer>
    
    
    <!--The BPM since that got disabled in the metrics-->
    <Layer Class="ActorFrame"
	OnCommand="addy,-800;sleep,0.1;decelerate,1;addy,800"><children>
        <Layer
            Font="_standard"
            Text=""
            InitCommand="%function(self) self:horizalign('center') self:x(SCREEN_CENTER_X); self:y(SCREEN_CENTER_Y-172); self:zoom(1); end"
            OnCommand="queuecommand,Update"
            UpdateCommand="%GameplayBPM"
            OffCommand="accelerate,0.8;addy,-100"
        />
    </children></Layer>

</children> </ActorFrame>