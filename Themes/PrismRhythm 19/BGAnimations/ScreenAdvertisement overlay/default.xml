<ActorFrame FOV="45" ><children>
	<AutoActor
		File="case"
		Command="x,SCREEN_CENTER_X-180;y,SCREEN_CENTER_Y;rotationy,-60;zoom,3;spin;EffectMagnitude,0,40,0"
	/>
	<ActorFrame OnCommand="x,SCREEN_CENTER_X+10;y,SCREEN_CENTER_Y;rotationy,-10" ><children>
		<AutoActor
			File="streak"
			OnCommand="zoom,0.5;fadeleft,0.3;faderight,0.3;cropleft,1.3;cropright,-0.3;linear,1;cropleft,-0.3;zoom,3;linear,11;zoom,2.8"
		/>
		<Layer
			Class="ActorFrame"
			InitCommand="x,+160;y,-52"
			OnCommand="zoom,0.8;addx,600;sleep,0.5;decelerate,0.5;addx,-600"
		><children>
			

<AutoActor
				File="logo"
				OnCommand="x,-50;y,26;shadowlength,2"
			/>
						



<Layer
				Class="BitmapText"
				Font="_v 26px bold shadow"
				Text="For PC and Mac"
				OnCommand="horizalign,right;x,+170;y,+110;shadowlength,0;zoom,1.4"
			/>
			<Layer
				Class="BitmapText"
				Font="_eurostile normal"
				Text=""
				OnCommand="horizalign,right;x,+170;y,+150;shadowlength,0;zoom,1.4"
			/>
			<Layer
				Class="BitmapText"
				Font="_r bold shadow 30px"
				Text="www.ITG3-Project.com"
				OnCommand="x,-48;y,+190;shadowlength,0;zoomx,1.2;zoomy,1"
			/>
		</children></Layer>
	</children></ActorFrame>
	<AutoActor
		File="../ScreenAttract overlay"
	/>


<Layer Type="File"
   File="Header Pane"
   InitCommand="diffusealpha,1"
   OnCommand="HorizAlign,Left;VertAlign,Top;X,SCREEN_LEFT+11;Y,SCREEN_TOP+22"
/>

		<Layer Type="BitmapText"
			Text="PrismRhythm 19 [ScreenAdvertisement] (Demo Loop 9/9)"
			File="_eurostile blue glow"
			InitCommand="X,SCREEN_LEFT+17;Y,SCREEN_TOP+20;shadowlength,0"
			OnCommand="horizalign,left;Zoom,.4"
		/>

		<Layer Type="BitmapText"
			Text="Demo Loop: Game Advertisement"
			File="_eurostile blue glow"
			InitCommand="X,SCREEN_LEFT+16;Y,SCREEN_TOP+32;shadowlength,2"
			OnCommand="horizalign,left;Zoom,.5"
		/>

		<Layer Type="BitmapText"
			Text="ITG Rebirth doesn't have a cover."
			File="_v profile"
			InitCommand="X,SCREEN_LEFT+17;Y,SCREEN_TOP+44;shadowlength,0"
			OnCommand="horizalign,left;Zoom,.4"
		/>

</children></ActorFrame>