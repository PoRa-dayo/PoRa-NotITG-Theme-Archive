<ActorFrame><children>
	<Layer
		File="../ScreenGameplay overlay/demonstration gradient"
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;zoomtowidth,SCREEN_WIDTH;zoomtoheight,SCREEN_HEIGHT;diffusealpha,0.8"
	/>

<!-- SONG NAME & PACK -->
<!-- Since it isn't displayed, tell possible viewers which song they're looking at,
     and where to find it in case they'd like to play it.  ITG3 does this, and it's
     really something that *should* be in a theme. -->

	<Layer
		Type="BitmapText"
		Font="_eurostile blue glow"
		InitCommand="animate,0;playcommand,Update"
		OnCommand="X,SCREEN_LEFT+120;Y,SCREEN_TOP+62;HorizAlign,Left;Zoom,.5;shadowlength,0;maxwidth,600"
		CurrentSongChangedMessageCommand="playcommand,Update"
		UpdateCommand="%function(self) self:settext(GetGroup(GAMESTATE:GetCurrentSong():GetSongDir())) end"
	/>

	<Layer
		Type="BitmapText"
		Font="_v profile"
		InitCommand="animate,0;playcommand,Update"
		OnCommand="X,SCREEN_LEFT+119;Y,SCREEN_TOP+75;HorizAlign,Left;Zoom,.5;shadowlength,0;maxwidth,600"
		CurrentSongChangedMessageCommand="playcommand,Update"
		UpdateCommand="%function(self) self:settext(GAMESTATE:GetCurrentSong():GetDisplayFullTitle()) end"
	/>

			<!-- DIFFICULTY ICON -->
			<ActorFrame
				Condition="GAMESTATE:IsPlayerEnabled(PLAYER_1)"
				OnCommand="X,SCREEN_LEFT+60;y,SCREEN_TOP+67"
				OffCommand="diffusealpha,0">
			<children>
			<Actor
				File="@THEME:GetPath(EC_GRAPHICS,'','_difficulty icons')"
				OnCommand="animate,0;playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self,parent) SetDifficultyFrameFromSteps(self, PLAYER_1) end"
			/>
			<Actor
				Class="DifficultyMeter"
				Type="ScreenGameplay DifficultyMeterP1"
				OnCommand="playcommand,Update"
				CurrentStepsP1ChangedMessageCommand="playcommand,Update"
				UpdateCommand="%function(self) self:SetFromSteps(GAMESTATE:GetCurrentSteps(PLAYER_1)) end"
			/>
			</children>
			</ActorFrame>

