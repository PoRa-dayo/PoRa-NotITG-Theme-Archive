<ActorFrame> <children>
	<Layer
		Type="Quad"
		OnCommand="Stretchto,-11,-114,11,114;diffuse,#000000"
	/>	
	<Layer
		Type="Quad"
		OnCommand="Stretchto,-11,-114,11,-144;blend,noeffect;zwrite,1"
	/>	
	<Layer
		File="Box.png"
		OnCommand="y,124;zoom,.37"
	/>	
	<ActorFrame
		OnCommand="queuecommand,Loop"
		LoopCommand="%function(self)
			local BPM = math.min(240,SCREENMAN:GetTopScreen():GetChild('BPMDisplay'):GetChild('Text'):GetText())
			self:queuemessage('Saw1')
			self:sleep(120/BPM)
			self:queuemessage('Saw2')
			self:sleep(120/BPM)
			self:queuemessage('Saw3')
			self:sleep(120/BPM)
			self:queuecommand('Loop')
		end"
	/>
	<Layer
		Type="ActorFrame"
		InitCommand="zoom,0"
		Saw1MessageCommand="finishtweening;y,124;zoom,0;linear,.17;zoom,.37;sleep,.26;queuemessage,Shoot;linear,.07;y,129;linear,1;y,-129"
	><children>
		<Layer
			File="saw.png"
			InitCommand="ztest,1;spin;effectmagnitude,0,0,270"
		/>
	</children></Layer>
	<Layer
		Type="ActorFrame"
		InitCommand="zoom,0"
		Saw2MessageCommand="finishtweening;y,124;zoom,0;linear,.17;zoom,.37;sleep,.26;queuemessage,Shoot;linear,.07;y,129;linear,1;y,-129"
	><children>
		<Layer
			File="saw.png"
			InitCommand="ztest,1;spin;effectmagnitude,0,0,270"
		/>
	</children></Layer>
	<Layer
		Type="ActorFrame"
		InitCommand="zoom,0"
		Saw3MessageCommand="finishtweening;y,124;zoom,0;linear,.17;zoom,.37;sleep,.26;queuemessage,Shoot;linear,.07;y,129;linear,1;y,-129"
	><children>
		<Layer
			File="saw.png"
			InitCommand="ztest,1;spin;effectmagnitude,0,0,270"
		/>
	</children></Layer>
	<Layer
		File="block.png"
		OnCommand="y,127;zoom,.37"
	/>
	<Layer
		Type="ActorFrame"
		InitCommand="y,127;spin;effectmagnitude,0,0,360"
	><children>
		<Layer
			Type="Quad"
			OnCommand="Stretchto,-4,-.8,4,.8;diffuse,#707070"
		/>
	</children></Layer>
	<Layer
		Type="ActorFrame"
		InitCommand="y,127;spin;effectmagnitude,0,0,360;rotationz,90"
	><children>
		<Layer
			Type="Quad"
			OnCommand="Stretchto,-4,-.8,4,.8;diffuse,#707070"
		/>
	</children></Layer>
	<Layer
		File="rod.png"
		OnCommand="y,129;zoom,.14;rotationz,180"
	/>
	<Layer
		File="Arrow.png"
		OnCommand="y,125;zoomx,.3;zoomy,.22"
		ShootMessageCommand="finishtweening;linear,.07;y,130;linear,.07;y,115;linear,.1;y,125"
	/>
</children> </ActorFrame>


