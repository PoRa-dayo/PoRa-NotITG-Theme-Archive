		OnCommand="x,300;y,-150"
		AnimateCommand="linear,1;x,0;y,0;queuecommand,Splode;sleep,1;x,300;y,-150"
	><children>
		<Layer File="_Missile 4x1.png" Command="y,-3;x,3;rotationz,-120;zoom,.25" SplodeCommand="zoom,0;sleep,2.15;zoom,.25" />
		<Layer Type="ActorFrame" Command="y,10;rotationz,60;zoom,.4" ><children>
			<Layer File="msplode.sprite" Command="y,77;rotationz,180" SplodeCommand="setstate,0" />
			<Layer File="msplode.sprite" Command="y,-77" SplodeCommand="setstate,0" />
		</children></Layer>
		<Layer Type="ActorFrame" Command="y,10;rotationz,60;zoom,.4" ><children>
			<Layer File="msplode.sprite" Command="y,77;rotationz,180;zwrite,1;blend,noeffect" SplodeCommand="setstate,0" />
			<Layer File="msplode.sprite" Command="y,-77;zwrite,1;blend,noeffect" SplodeCommand="setstate,0" />
		</children></Layer>
	</children></Layer>
</children></ActorFrame>