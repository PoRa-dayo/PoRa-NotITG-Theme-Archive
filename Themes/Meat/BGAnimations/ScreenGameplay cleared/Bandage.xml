<ActorFrame><children>
	<ActorFrame
		InitCommand="%function() BandageGet = 0 end"
		AnimateCommand="%function(self) if BandageGet == 0 then BandageGet = 1; self:queuecommand('Sound1') self:sleep(.5) self:queuecommand('Sound2') end end" 
		Sound1Command="%function() Sound('Swirl_02.ogg') end" 
		Sound2Command="%function() Sound('band_aid_pick_up.ogg') BandageGet = 0 end"
	/>
	<Layer Type="ActorFrame" Command="x,-46;y,51;zoom,0;" AnimateCommand="zoom,.7;rotationz,10;linear,.4;rotationz,360;zoomx,.335;zoomy,.345" ><children>
		<Layer Type="ActorFrame" AnimateCommand="sleep,0.3;linear,.1;zoomy,.7;zoomx,1.15;linear,.1;zoomx,.85;zoomy,1.3;linear,.1;zoom,1" ><children>
			<Layer File="Bandage.png" />
			<Layer File="Bandage white 2.png" AnimateCommand="diffusealpha,0;linear,.3;diffusealpha,1;sleep,.2;linear,.1;diffusealpha,0" />
		</children></Layer>
		<Layer File="Bandage white 1.png" AnimateCommand="diffusealpha,.35;sleep,0.4;diffusealpha,1;linear,.1;zoomx,.85;zoomy,1.3;linear,.2;zoomx,1.25;zoomy,2;diffusealpha,.2;sleep,0;diffusealpha,0" />
		<Layer Font="_Meat" Text="Bandage Get!" AnimateCommand="zoom,.96;x,8;y,-2;shadowlength,0;Diffuse,#FC679700;sleep,0.6;linear,.3;y,0;diffusealpha,1" />
	</children></Layer>
</children></ActorFrame>