<ActorFrame><children>
	<Layer
		Type="ActorFrame"
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
	><children>
		<Layer File="blood fall.sprite" OnCommand="zoom,.55;y,25" />
		<Layer File="blood fall.sprite" OnCommand="zoom,.55;y,105" />

		<Layer File="blood pit.sprite" Command="y,172;zoom,.65" />

		<Layer File="spikesr.png" Command="y,68;x,-110;zoom,.4;rotationz,90" />
		<Layer File="spikesr.png" Command="y,42;x,-110;zoom,.4;rotationz,90" />
		<Layer File="spikesr.png" Command="y,68;x,110;zoom,.4;rotationz,90;rotationy,180" />
		<Layer File="spikesr.png" Command="y,42;x,110;zoom,.4;rotationz,90;rotationy,180" />

	</children></Layer>

	<Layer File="key.png" InitCommand="x,SCREEN_CENTER_X-130;y,SCREEN_CENTER_Y-67;zoom,.3" OnCommand="%function(self) Register(self,-6,-10,6,10,6) end" HeroCommand="zoom,0" />
	<Layer File="key.png" InitCommand="x,SCREEN_CENTER_X+130;y,SCREEN_CENTER_Y-67;zoom,.3" OnCommand="%function(self) Register(self,-6,-10,6,10,6) end" HeroCommand="zoom,0" />

	<ActorFrame
		OnCommand="%function(self)
		x = SCREEN_CENTER_X; y = SCREEN_CENTER_Y
		Register(self,x-16,y-30,x+16,y+160,4)
		Register(self,x-65,y+160,x+65,y+178,4)

		Register(self,x-117,y+30,x-100,y+80,4)
		Register(self,x+117,y+30,x+100,y+80,4)

		end"
	/>

</children></ActorFrame>