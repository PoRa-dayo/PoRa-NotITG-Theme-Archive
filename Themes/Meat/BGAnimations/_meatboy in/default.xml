					File="saw.png"
					OnCommand="rotationz,22.5;diffusealpha,.47;sleep,.3;linear,.3;diffusealpha,0"
				/>
				<Layer
					File="saw.png"
					OnCommand="sleep,.3;linear,.3;diffusealpha,0"
