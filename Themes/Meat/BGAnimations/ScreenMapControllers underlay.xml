<ActorFrame><children>
	<ActorFrame
		Command="queuecommand,Screen" 
		ScreenCommand="%function() 
			s = SCREENMAN:GetTopScreen(); s:zoomy(.8); s:y(SCREEN_CENTER_Y*.2);
			s = s:GetChild('Underlay') s:zoomy(1.25) s:y(-SCREEN_CENTER_Y*.25); end"
	/>
	<Layer Type="Quad" Command="stretchto,SCREEN_CENTER_X-400,SCREEN_CENTER_Y-300,SCREEN_CENTER_X+400,SCREEN_CENTER_Y+300;diffuse,#00000000;linear,.25;diffusealpha,.705" FinishMessageCommand="linear,.25;diffusealpha,0" />
	<Layer 
		Type="ActorFrame" 
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y+500;linear,.1;addy,-520;zoom,1.4;linear,.05;zoomx,1.3;zoomy,1.6;linear,.1;zoom,1;addy,20" 
		FinishMessageCommand="linear,.1;zoomx,1.3;zoomy,1.6;addy,-20;linear,.05;zoom,1.4;linear,.1;addy,520;zoom,1"
	><children>
		<Layer Type="Quad" Command="stretchto,-308,-198,304,210;diffuse,#000000" />
		<Layer File="ScreenOptions underlay/Banner.png" Command="x,-2;y,-196;zoomx,1.37;zoomy,.64" />
		<Layer File="ScreenOptions underlay/Bar.png" Command="diffuse,#777777;x,-2;y,-188;zoomx,1;zoomy,.5" />
		<Layer File="ScreenOptions underlay/Banner.png" Command="x,-2;y,207;zoomx,1.41;zoomy,.34" />
	</children></Layer>
	<Layer Type="ActorFrame" OnCommand="x,SCREEN_CENTER_X-175;y,SCREEN_CENTER_Y;zoom,0;sleep,.25;zoom,1" FinishMessageCommand="zoom,0" ><children>
		<Layer Font="_Meat" Text="&START;" OnCommand="x,-90;y,207;shadowlength,0;zoom,.7" />
		<Layer Font="_Meat" Text="Select" OnCommand="x,-45;y,206;shadowlength,0;zoom,.37;diffuse,#000000" />
		<Layer Font="_Meat" Text="Key Mappings" Command="x,175;y,-200;shadowlength,0;diffuse,#000000;zoom,.5" />
	</children></Layer>
</children><ActorFrame>