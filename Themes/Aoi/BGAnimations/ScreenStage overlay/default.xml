<ActorFrame><children>
	<!-- This will act as the BGAnimation LengthSeconds command. -->
	<Layer Type="Quad" OnCommand="%function(self) self:zoom(0) self:sleep(1.75) end" />

	<!-- OpenITG's Center isn't the ACTUAL center; it's the top left corner, so we need to center it again. -->
	<!-- StepMania 3.9's CenterX is 320, and CenterY is 240. So i need to do some math in order to makeout what the actual value is using SCREEN_CENTER_Y first and then the value. Thankfully we can let OpenITG do the actual math. -->
	<Layer File="../_shared background/bg" OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;customtexturerect,0,0,2,1;texcoordvelocity,0.16,0;zoomx,2" />
	<Layer File="../stars.jpg" OnCommand="%function(self)
        if StarCheck() then
            self:xywh(SCREEN_CENTER_X,SCREEN_CENTER_Y+100,1024,768)
            self:customtexturerect(0,0,1,1)
            self:texcoordvelocity(0.12,0)
            self:diffusealpha(0)
            self:linear(0.5)
            self:diffusealpha(1)
        else
            self:zoom(0)
        end
    end" />

	<Layer File="../STAGE/b-back.png" OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y+(361-240);diffusealpha,0;decelerate,0.2;diffusealpha,0.4;sleep,1.3;accelerate,0.25;diffusealpha,0" />
	<Layer File="@'stage '..GetStageText()" OnCommand="horizalign,left;x,SCREEN_CENTER_X+(14-320);y,SCREEN_CENTER_Y+(217-240);addx,-200;diffusealpha,0;decelerate,0.3;diffusealpha,0.4;addx,200;sleep,1.2;accelerate,0.25;diffusealpha,0" />

	<Layer File="../STAGE/stuff.png"
        OnCommand="%function(self)
        if GAMESTATE:IsCourseMode() then
            self:zoom(0)
        else
            self:x(SCREEN_CENTER_X)
            self:addx(-200)
            self:y(SCREEN_CENTER_Y+(347-240))
            self:diffusealpha(0)
            self:decelerate(0.3)
            self:diffusealpha(1)
            self:addx(200)
            self:sleep(1.2)
            self:accelerate(0.25)
            self:diffusealpha(0)
        end
    end" />
        
    <Layer File="../STAGE/stuff2.png"
        OnCommand="%function(self)
        if GAMESTATE:IsCourseMode() then
            self:x(SCREEN_CENTER_X)
            self:addx(-200)
            self:y(SCREEN_CENTER_Y+(347-240))
            self:diffusealpha(0)
            self:decelerate(0.3)
            self:diffusealpha(1)
            self:addx(200)
            self:sleep(1.2)
            self:accelerate(0.25)
            self:diffusealpha(0)
        else
            self:zoom(0)
        end
    end" />

	<Layer File="../startsov.png" Condition="StarCheck()" OnCommand="x,SCREEN_CENTER_X;addx,-200;y,SCREEN_CENTER_Y+(335-240);diffusealpha,0;decelerate,0.3;diffusealpha,1;addx,200;sleep,1.2;accelerate,0.25;diffusealpha,0" />

	<Layer File="../STAGE/ring.png" OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;zoom,0;diffusealpha,0;accelerate,0.7;zoom,10;diffusealpha,1;hibernate,1.05" />
	<Layer File="../STAGE/arrow.png" OnCommand="x,SCREEN_CENTER_X+(383-320);y,SCREEN_CENTER_Y+(202-240);diffusealpha,0.7;hibernate,0.2;zoom,0;decelerate,0.5;zoom,1;addx,250;addy,-250" />
	<Layer File="../STAGE/arrow.png" OnCommand="x,SCREEN_CENTER_X+(433-320);y,SCREEN_CENTER_Y+(252-320);diffusealpha,0.7;hibernate,0.4;zoom,0;decelerate,0.6;zoom,0.5;addx,270;addy,-270" />

	<Layer File="songbanner"
        OnCommand="%function(self)
        if GAMESTATE:IsCourseMode() then
            self:zoom(0)
        else
            self:x(SCREEN_CENTER_X+(156-320))
            self:y(SCREEN_CENTER_Y+(382-240))
            self:zoomtowidth(256)
            self:zoomtoheight(80)
            self:addx(-200)
            self:diffusealpha(0)
            self:decelerate(0.3)
            self:diffusealpha(1)
            self:addx(200)
            self:sleep(1.2)
            self:accelerate(0.25)
            self:diffusealpha(0)
        end
    end" />
    <Layer File="coursebanner"
        OnCommand="%function(self)
        if GAMESTATE:IsCourseMode() then
            self:x(SCREEN_CENTER_X+(156-320))
            self:y(SCREEN_CENTER_Y+(382-240))
            self:zoomtowidth(256)
            self:zoomtoheight(80)
            self:addx(-200)
            self:diffusealpha(0)
            self:decelerate(0.3)
            self:diffusealpha(1)
            self:addx(200)
            self:sleep(1.2)
            self:accelerate(0.25)
            self:diffusealpha(0)
        else
            self:zoom(0)
        end
    end" />


	<Layer File="songbackground"
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;hibernate,1.5;zoomtowidth,700;zoomtoheight,0;diffusealpha,0;accelerate,0.25;diffusealpha,1;zoomtoheight,480;zoomtowidth,640" />


    <Layer Font="_shared1"
        Text=""
        OnCommand="%function(self)
        if GAMESTATE:IsCourseMode() then
            SongTitle(self)
            self:x(SCREEN_CENTER_X+(308-320))
            self:y(SCREEN_CENTER_Y+(358-240))
            self:horizalign('left')
            self:shadowlength(0)
            self:addx(-200)
            self:diffusealpha(0)
            self:decelerate(0.3)
            self:diffusealpha(1)
            self:addx(200)
            self:sleep(1.2)
            self:accelerate(0.25)
            self:diffusealpha(0)
        else
            self:zoom(0)
        end
    end" />
</children></ActorFrame>
