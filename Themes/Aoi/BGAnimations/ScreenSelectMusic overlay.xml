<!-- The extra difficulty number for diffs above 10 -->
<ActorFrame
    CurrentSongChangedMessageCommand="queuecommand,SendUpdate"
    CurrentStepsP1ChangedMessageCommand="queuecommand,SendUpdate"
    CurrentStepsP2ChangedMessageCommand="queuecommand,SendUpdate"
    SendUpdateCommand="%function(self)
    MESSAGEMAN:Broadcast('Update')
    end"
    ><children>
    <Layer
        File="bonus diff frame"
        Condition="not GAMESTATE:IsCourseMode() and GAMESTATE:IsPlayerEnabled(PLAYER_1)"
        OnCommand="x,SCREEN_CENTER_X-30;y,SCREEN_CENTER_Y+107;hidden,1;"
        OffCommand="diffusealpha,1;accelerate,0.25;diffusealpha,0"
        UpdateMessageCommand="%function(self) DiffFrameBonus(self, PLAYER_1) end"
    />
        <Layer
        Font="ScreenManager credits"
        Text=""
        Condition="not GAMESTATE:IsCourseMode() and GAMESTATE:IsPlayerEnabled(PLAYER_1)"
        OnCommand="x,SCREEN_CENTER_X-37;y,SCREEN_CENTER_Y+110;rainbow;effectperiod,2;horizalign,left;shadowlength,0;"
        OffCommand="diffusealpha,1;accelerate,0.25;diffusealpha,0"
        UpdateMessageCommand="%function(self) LevelNum(self, PLAYER_1) end"
    />
    
    <Layer
        File="bonus diff frame"
        Condition="not GAMESTATE:IsCourseMode() and GAMESTATE:IsPlayerEnabled(PLAYER_2)"
        OnCommand="x,SCREEN_CENTER_X-30;y,SCREEN_CENTER_Y+168;hidden,1;"
        OffCommand="diffusealpha,1;accelerate,0.25;diffusealpha,0"
        UpdateMessageCommand="%function(self) DiffFrameBonus(self, PLAYER_2) end"
    />
    <Layer
        Font="ScreenManager credits"
        Text=""
        Condition="not GAMESTATE:IsCourseMode() and GAMESTATE:IsPlayerEnabled(PLAYER_2)"
        OnCommand="x,SCREEN_CENTER_X-37;y,SCREEN_CENTER_Y+171;rainbow;effectperiod,2;horizalign,left;shadowlength,0;"
        OffCommand="diffusealpha,1;accelerate,0.25;diffusealpha,0"
        UpdateMessageCommand="%function(self) LevelNum(self, PLAYER_2) end" />
    
    
    <!-- the timer -->
	<Layer File="_shared background/circle.png"
	OnCommand="spin;effectperiod,0.5;x,SCREEN_RIGHT-45;y,SCREEN_CENTER_Y+(-76-240);diffusealpha,0;decelerate,0.5;diffusealpha,1;addy,100" OffCommand="diffusealpha,1;accelerate,0.5;addy,-100;diffusealpha,0"/>
	<Layer File="ScreenOptions background/time.png" OnCommand="horizalign,right;x,SCREEN_RIGHT;y,SCREEN_CENTER_Y+(24-240);addy,-100;diffusealpha,0;decelerate,0.5;diffusealpha,1;addy,100" OffCommand="diffusealpha,1;accelerate,0.5;addy,-100;diffusealpha,0"/>
</children></ActorFrame>