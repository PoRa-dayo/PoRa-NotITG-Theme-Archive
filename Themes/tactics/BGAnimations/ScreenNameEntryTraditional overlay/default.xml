<ActorFrame><children>
	<ActorFrame
		Condition="GAMESTATE:IsPlayerEnabled(PLAYER_1)"
		OnCommand="x,SCREEN_CENTER_X-284;y,SCREEN_CENTER_Y-215"
		OffCommand="hidden,1"
	> <children>
		<Actor
			File="Lv.png"
		/>
		<Actor
			File="exp.png"
			OnCommand="x,6;y,40"
		/>
	</children> </ActorFrame>
	<ActorFrame
		Condition="GAMESTATE:IsPlayerEnabled(PLAYER_2)"
		OnCommand="x,SCREEN_CENTER_X+156;y,SCREEN_CENTER_Y-215"
		OffCommand="hidden,1"
	> <children>
		<Actor
			File="Lv.png"
		/>
		<Actor
			File="exp.png"
			OnCommand="x,6;y,40"
		/>
	</children> </ActorFrame>
	<Layer 
		File="background.png" 
		InitCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y-196"
		OnCommand="zoom,0" 
		OffCommand="zoom,1"
	/>
	<Layer Type="ActorFrame" OnCommand="zoom,0" OffCommand="zoom,1" ><children>
		<Layer
			File="BG2.png"
			InitCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
		/>
		<Layer
			File="BG1.png"
			InitCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
			OnCommand="fadebottom,0;cropbottom,0;sleep,12;fadebottom,.1;linear,3;cropbottom,1.2"
		/>
	</children></Layer>
	<Layer
		File="../_fade in normal"
	/>
	<Layer Type="ActorFrame"
		InitCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y-80" 
		OnCommand="%function(self)
					if not GAMESTATE:IsPlayerEnabled(PLAYER_2) then 
						self:x(self:GetX()+90); self:y(self:GetY()+60)
					end
					if not GAMESTATE:IsPlayerEnabled(PLAYER_1) then 
						self:x(self:GetX()-90); self:y(self:GetY()+60)
					end	
			end"
		><children>
		<Layer
			File="@GetClassShadow()"
		/>
		<Layer
			Condition="OnePassed() and GAMESTATE:AnyPlayerHasRankingFeats() or GetBestFinalGrade() <= GRADE_TIER05"
			File="@GetClass()"
			InitCommand="@GetClassInit()"
		/>
		<Layer
			Condition="OnePassed() and not GAMESTATE:AnyPlayerHasRankingFeats() and GetBestFinalGrade() > GRADE_TIER05"
			File="@GetClass()"
			InitCommand="@GetClassHurt()"
		/>
		<Layer 
			Condition="not OnePassed()"
			File="@GetClass()"
			InitCommand="@GetClassDead()"	
		 />
		</children>
	</Layer>
	<Layer
		File="@THEME:GetPath( EC_BGANIMATIONS, '', '_boarder' )"
	/>
</children></ActorFrame>
