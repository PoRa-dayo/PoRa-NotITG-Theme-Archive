<ActorFrame><children>
		<AutoActor File="_fade in normal" />
		<ActorFrame Condition="not OnePassed()"
			><children>
				<Actor
				File="_black"
				OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;ZoomToWidth,SCREEN_WIDTH;ZoomToHeight,SCREEN_HEIGHT;diffusealpha,1;sleep,3;diffusealpha,0"
				/>
				<Layer File="Game Over"
				OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y;faderight,0.3;cropright,1.3;cropleft,-0.3;linear,3;cropright,-0.3;sleep,1;linear,1;diffusealpha,0"
				/>
			</children>
		</ActorFrame>
		<Layer Type="ActorFrame" InitCommand="x,SCREEN_CENTER_X+6;y,SCREEN_CENTER_Y+105" OffCommand="zoom,0"><children>
			<Layer
				File="@GetClassShadow()"
			/>
			<Layer 
				Condition="OnePassed() and STATSMAN:GetBestGrade() <= GRADE_TIER08"
				File="@GetClass()"
				InitCommand="@GetClassInit()"	
			 />
			<Layer 
				Condition="OnePassed() and STATSMAN:GetBestGrade() > GRADE_TIER08"
				File="@GetClass()"
				InitCommand="@GetClassHurt()"	
			 />
			<Layer 
				Condition="not OnePassed()"
				File="@GetClass()"
				InitCommand="@GetClassDead()"	
			 />
		</children></Layer>
</children></ActorFrame>
