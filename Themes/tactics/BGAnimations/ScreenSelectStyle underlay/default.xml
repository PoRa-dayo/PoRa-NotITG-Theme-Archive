<ActorFrame> <children>
	<Layer Type="ActorFrame"
		Condition="GAMESTATE:GetEnv('mode') == 'survival'" 
		InitCommand="x,SCREEN_CENTER_X-30;y,SCREEN_CENTER_Y-4"
		OnCommand="linear,.2;x,SCREEN_CENTER_X-60;y,SCREEN_CENTER_Y-4;linear,.3;x,SCREEN_CENTER_X-100;y,SCREEN_CENTER_Y-16;linear,.30;x,SCREEN_CENTER_X-160;y,SCREEN_CENTER_Y-16;linear,.2;x,SCREEN_CENTER_X-196;y,SCREEN_CENTER_Y-36;linear,.25;x,SCREEN_CENTER_X-204;y,SCREEN_CENTER_Y-72"
		><children>
		<Layer
			File="down"
			OnCommand="zoom,0;sleep,1.35;zoom,1"
		/>
		<Layer
			File="left"
			OnCommand="zoom,1;sleep,.2;zoom,0;sleep,.3;zoom,1;sleep,.3;zoom,0"
		/>
		<Layer
			File="up left"
			OnCommand="zoom,0;sleep,.2;zoom,1;sleep,.3;zoom,0;sleep,.3;zoom,1;sleep,.2;zoom,0"
		/>
		<Layer
			File="up"
			OnCommand="zoom,0;sleep,1;zoom,1;sleep,.35;zoom,0"
		/>
	</children></Layer>
	<Layer Type="ActorFrame"
		Condition="GAMESTATE:GetEnv('mode') == 'marathon'" 
		InitCommand="x,SCREEN_CENTER_X-30;y,SCREEN_CENTER_Y-4"
		OnCommand="linear,.15;x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y-4;linear,.4;x,SCREEN_CENTER_X+80;y,SCREEN_CENTER_Y-40;linear,.25;x,SCREEN_CENTER_X+130;y,SCREEN_CENTER_Y-40;linear,.3;x,SCREEN_CENTER_X+190;y,SCREEN_CENTER_Y-16;linear,.15;x,SCREEN_CENTER_X+220;y,SCREEN_CENTER_Y-16"
		><children>
		<Layer
			File="down"
			OnCommand="zoom,0;sleep,1.35;zoom,1"
		/>
		<Layer
			File="right"
			OnCommand="zoom,1;sleep,.15;zoom,0;sleep,.4;zoom,1;sleep,.25;zoom,0;sleep,.3;zoom,1;sleep,.25;zoom,0"
		/>
		<Layer
			File="up right"
			OnCommand="zoom,0;sleep,.15;zoom,1;sleep,.4;zoom,0"
		/>
		<Layer
			File="down right"
			OnCommand="zoom,0;sleep,.8;zoom,1;sleep,.3;zoom,0"
		/>
	</children></Layer>
	<Layer Type="ActorFrame"
		Condition="GAMESTATE:GetEnv('mode') == 'dance'" 
		InitCommand="x,SCREEN_CENTER_X-30;y,SCREEN_CENTER_Y-4"
		OnCommand="linear,.2;x,SCREEN_CENTER_X-23;y,SCREEN_CENTER_Y+28;linear,.2;x,SCREEN_CENTER_X-10;y,SCREEN_CENTER_Y+51;linear,.2;x,SCREEN_CENTER_X-3;y,SCREEN_CENTER_Y+78;linear,.2;x,SCREEN_CENTER_X+25;y,SCREEN_CENTER_Y+93;linear,.45;x,SCREEN_CENTER_X+38;y,SCREEN_CENTER_Y+166"
		><children>
		<Layer
			File="down"
			OnCommand="zoom,1;sleep,.2;zoom,0;sleep,.2;zoom,1;sleep,.2;zoom,0;sleep,.2;zoom,1"
		/>
		<Layer
			File="down right"
			OnCommand="zoom,0;sleep,.2;zoom,1;sleep,.2;zoom,0;sleep,.2;zoom,1;sleep,.2;zoom,0"
		/>
	</children></Layer>
	<Layer Type="ActorFrame" 
		Condition="GAMESTATE:GetEnv('mode') == 'dance'" 
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
		><children>
		<Layer 
			File="Dance Mode.png"
			OnCommand="y,-70;zoom,0;sleep,1.3;linear,.2;zoom,1"
		/>			
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text="Dance Mode"
			InitCommand="zoomx,1.25;shadowlength,0;y,10"
			OnCommand="diffuse,0,0,0,0;sleep,1.3;diffuse,0,0,0,1;linear,.5;diffuse,1,1,1,1"
		/>
	</children></Layer>
	<Layer Type="ActorFrame" 
		Condition="GAMESTATE:GetEnv('mode') == 'marathon'" 
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
		><children>
		<Layer 
			File="Marathon Mode.png"
			OnCommand="y,-70;zoom,0;sleep,1.3;linear,.2;zoom,1"
		/>			
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text="Marathon Mode"
			InitCommand="zoomx,1.25;shadowlength,0;y,10"
			OnCommand="diffuse,0,0,0,0;sleep,1.3;diffuse,0,0,0,1;linear,.5;diffuse,1,1,1,1"
		/>
	</children></Layer>
	<Layer Type="ActorFrame" 
		Condition="GAMESTATE:GetEnv('mode') == 'survival'" 
		OnCommand="x,SCREEN_CENTER_X;y,SCREEN_CENTER_Y"
		><children>
		<Layer 
			File="Survival Mode.png"
			OnCommand="y,-70;zoom,0;sleep,1.3;linear,.2;zoom,1"
		/>			
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text="Survival Mode"
			InitCommand="zoomx,1.25;shadowlength,0;y,10"
			OnCommand="diffuse,0,0,0,0;sleep,1.3;diffuse,0,0,0,1;linear,.5;diffuse,1,1,1,1"
		/>
	</children></Layer>
</children> </ActorFrame>
