<ActorFrame><children>
	<ActorFrame 
		GainFocusCommand="sleep,.15;zoom,1"
		LoseFocusCommand="sleep,.15;zoom,0"
		><children>
		<Layer 
			File="@GetClassPath('042')"
			OnCommand="addx,-194;addy,-111"
			InitCommand="@GetClassBanner('042')"
		/>
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text=""
			InitCommand="y,-204;x,-80;shadowlength,0;horizalign,left;zoom,1.25;zoomy,1"
			OnCommand="%function(self) self:settext(GetClassName('042')) end"
			/>
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text=""
			InitCommand="y,-176;x,-80;shadowlength,0;horizalign,left;zoom,1.25;zoomy,1"
			OnCommand="%function(self) self:settext(GetClassCode('042')) end"
		/>
		<Layer 
			File="@GetClassPath('042')"
			OnCommand="addx,180"
			InitCommand="@GetClassDead('042')"
		/>
		<Layer 
			File="@GetClassPath('042')"
			InitCommand="@GetClassHurt('042')"
		/>
		<Layer Type="ActorFrame" 
			Condition="GetClassType('042') == '1'"
			OnCommand="addx,-180"
			><children>
			<Layer
				File="@GetChocobo()"
				InitCommand="@GetChocoboInit()"
			/>
			<Layer Type="ActorFrame" InitCommand="x,5;y,-19"><children>
				<Layer
					File="@GetClassPath('042')"
					InitCommand="@GetClassRiding1('042')"
				/>
				<Layer
					File="@GetClassPath('042')"
					InitCommand="@GetClassRiding2('042')"
				/>
			</children></Layer>
			<Layer
				File="@GetChocoboOverlay()"
				InitCommand="@GetChocoboInit()"
			/>		
		</children></Layer>
		<Layer
			Condition="GetClassType('042') ~= '1'"
			File="@GetClassPath('042')"
			OnCommand="addx,-180"
			InitCommand="@GetClassInit('042')"
		/>		
	</children></ActorFrame>
</children></ActorFrame>
