<ActorFrame><children>
	<ActorFrame 
		GainFocusCommand="sleep,.15;zoom,1"
		LoseFocusCommand="sleep,.15;zoom,0"
		><children>
		<Layer 
			File="@GetClassPath('112')"
			OnCommand="addx,-194;addy,-111"
			InitCommand="@GetClassBanner('112')"
		/>
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text=""
			InitCommand="y,-204;x,-80;shadowlength,0;horizalign,left;zoom,1.25;zoomy,1"
			OnCommand="%function(self) self:settext(GetClassName('112')) end"
			/>
		<Layer Type="BitmapText"
			Font="_FFT2 white"
			Text=""
			InitCommand="y,-176;x,-80;shadowlength,0;horizalign,left;zoom,1.25;zoomy,1"
			OnCommand="%function(self) self:settext(GetClassCode('112')) end"
		/>
		<Layer 
			File="@GetClassPath('112')"
			OnCommand="addx,180"
			InitCommand="@GetClassDead('112')"
		/>
		<Layer 
			File="@GetClassPath('112')"
			InitCommand="@GetClassHurt('112')"
		/>
		<Layer
			File="@GetClassPath('112')"
			OnCommand="addx,-180"
			InitCommand="@GetClassInit('112')"
		/>		
	</children></ActorFrame>
</children></ActorFrame>
